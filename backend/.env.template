OPENAI_API_KEY=your-openai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

LANGFUSE_PUBLIC_KEY=pk-lf-your-local-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-local-secret-key
LANGFUSE_HOST=http://localhost:3000

# LLM Routing — comma-separated provider order per task type
ENABLE_LLM_FALLBACK=true
LLM_ROUTER_PROVIDER=local,openrouter,codex
LLM_GENERAL_PROVIDER=openrouter,codex
LLM_RAG_PROVIDER=openrouter,codex
LLM_KG_PROVIDER=openrouter,codex
LLM_VISUAL_PROVIDER=openrouter,codex
LLM_EVAL_PROVIDER=openrouter,codex

# Codex Fallback Toggles to prevent quota burn
ENABLE_CODEX_FALLBACK_FOR_BATCH=false
ENABLE_CODEX_FALLBACK_FOR_INTERACTIVE=false
