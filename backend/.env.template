OPENAI_API_KEY=your-openai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

LANGFUSE_PUBLIC_KEY=pk-lf-your-local-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-local-secret-key
LANGFUSE_HOST=http://localhost:3000

# LLM Routing — comma-separated provider order per task type
ENABLE_LLM_FALLBACK=true
ENABLE_OPENROUTER_FALLBACK=false
LLM_ROUTER_PROVIDER=local,groq,codex
LLM_GENERAL_PROVIDER=groq,codex
LLM_RAG_PROVIDER=groq,codex
LLM_KG_PROVIDER=groq,codex
LLM_VISUAL_PROVIDER=groq,codex
LLM_EVAL_PROVIDER=groq,codex

# Codex Fallback Toggles to prevent quota burn
ENABLE_CODEX_FALLBACK_FOR_BATCH=false
ENABLE_CODEX_FALLBACK_FOR_INTERACTIVE=false
